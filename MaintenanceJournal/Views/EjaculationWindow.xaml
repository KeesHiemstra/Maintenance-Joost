<Window x:Class="MaintenanceJournal.Views.EjaculationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MaintenanceJournal.Views"
        mc:Ignorable="d"
        Title="Ejaculation report" 
        Height="450" 
        Width="250"
        KeyUp="Window_KeyUp">
  <Grid>

    <TabControl
      Margin="5"
      SelectedIndex="1">

      <TabItem
        Header="Day">
        <DataGrid
          x:Name="EjaculationDaysDataGrid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          ItemsSource="{Binding EjaculationList}">
          <DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Header="Date" />
            <DataGridTextColumn Binding="{Binding Total}" Header="Count" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

      <TabItem
        Header="Week">
        <DataGrid
          x:Name="EjaculationWeeksDataGrid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          ItemsSource="{Binding EjaculationList}">
          <DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Header="Date" />
            <DataGridTextColumn Binding="{Binding Total}" Header="Count" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

      <TabItem
        Header="Month">
        <DataGrid
          x:Name="EjaculationMonthsDataGrid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          ItemsSource="{Binding EjaculationList}">
          <DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Header="Date" />
            <DataGridTextColumn Binding="{Binding Total}" Header="Count" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

      <TabItem
        Header="Quarter">
        <DataGrid
          x:Name="EjaculationQuartersDataGrid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          ItemsSource="{Binding EjaculationList}">
          <DataGrid.Columns>
            <DataGridTextColumn Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Header="Date" />
            <DataGridTextColumn Binding="{Binding Total}" Header="Count" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

    </TabControl>
    
  </Grid>
</Window>
